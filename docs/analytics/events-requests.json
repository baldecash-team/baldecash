  "batchExample": {
    "description": "Ejemplo de cómo se envían 3 eventos juntos en un batch. El cliente acumula eventos y los flushea cada 5s (o al ocultar la pestaña).",
    "request": {
      "method": "POST",
      "url": "/api/v1/public/events/batch",
      "body": {
        "session_id": "7c3a4e12-9b45-4f82-b9e1-4d2a8f3c1e27",
        "events": [
          {
            "event_type": "filter_toggle",
            "client_ts": 1776902400000,
            "page_url": "/catalogo",
            "element_id": null,
            "properties": {
              "landing": "ucv",
              "filter_code": "brand",
              "value": "apple",
              "active": true,
              "section": "catalog"
            }
          },
          {
            "event_type": "product_click",
            "client_ts": 1776902410000,
            "page_url": "/catalogo",
            "element_id": null,
            "properties": {
              "landing": "ucv",
              "product_id": "42",
